<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Main TTO Announcer</title>

<style>
  body {
    background:#f5f7fb;
    font-family:-apple-system,system-ui,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    color:#0f172a;
    margin:0;
    text-align:center;
  }

  #call {
    display:none;
    width:min(960px,94vw);
    margin:40px auto;
    background:#000;
    color:#fff;
    border-radius:16px;
    padding:32px 18px;
    font-weight:800;
    font-size:clamp(26px,4.5vw,40px);
    line-height:1.6;
  }

  #call b {
    font-weight:900;
  }

  #englishCall {
    direction:ltr;
    margin-top:14px;
    font-size:clamp(20px,3.5vw,32px);
    color:#cbd5e1;
  }

  #soundGate {
    position:fixed;
    inset:0;
    display:flex;
    align-items:center;
    justify-content:center;
    background:rgba(0,0,0,.82);
    color:#fff;
    z-index:10;
    font-size:22px;
    padding:20px;
  }

  #soundGate button {
    margin-top:14px;
    padding:12px 22px;
    border:0;
    border-radius:10px;
    background:#2563eb;
    color:#fff;
    font-weight:800;
    font-size:18px;
    cursor:pointer;
  }

  #status {
    margin-top:20px;
    color:#475569;
    font-weight:700;
    font-size:16px;
    padding:0 16px;
  }
</style>

<script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-database-compat.js"></script>
</head>

<body>

<div id="soundGate">
  <div>
    اضغط تفعيل الصوت مرة واحدة للسماح بالنداء العربي والإنجليزي.
    <br>
    <button id="enableBtn">تفعيل الصوت</button>
  </div>
</div>

<div id="call">
  <div id="arabicCall">
    تذكرة رقم (<b id="tNum"></b>)
    <span id="wWrap" style="display:none">
      ، الرجاء التوجه إلى شباك <b id="wNum"></b>
    </span>
  </div>

  <div id="englishCall">
    Ticket number <b id="tNumEn"></b>
    <span id="wWrapEn" style="display:none">
      , please proceed to counter <b id="wNumEn"></b>
    </span>
  </div>
</div>

<div id="status">Main TTO Announcer</div>

<script>
(function(){

  /* ========== Firebase ========== */

  const cfg = {
    apiKey:"AIzaSyCWWnMsge75Q3_MDF9Aj9wo4C5KD6RVGfw",
    authDomain:"q-matic-b7d77.firebaseapp.com",
    databaseURL:"https://q-matic-b7d77-default-rtdb.firebaseio.com",
    projectId:"q-matic-b7d77",
    storageBucket:"q-matic-b7d77.appspot.com",
    messagingSenderId:"908187704899",
    appId:"1:908187704899:web:b8bcf33cda90bafe81bef6"
  };

  if (!firebase.apps.length) {
    firebase.initializeApp(cfg);
  }

  const db = firebase.database();
  const ROOT = "main_TTO";

  /* ========== العناصر ========== */

  const callEl    = document.getElementById("call");

  const tNumEl    = document.getElementById("tNum");
  const wWrap     = document.getElementById("wWrap");
  const wNumEl    = document.getElementById("wNum");

  const tNumEnEl  = document.getElementById("tNumEn");
  const wWrapEn   = document.getElementById("wWrapEn");
  const wNumEnEl  = document.getElementById("wNumEn");

  const soundGate = document.getElementById("soundGate");
  const enableBtn = document.getElementById("enableBtn");
  const statusEl  = document.getElementById("status");

  /* ========== أدوات عامة ========== */

  function wait(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  function normalizeValue(value) {
    if (value == null) return null;

    if (typeof value === "string") {
      const trimmed = value.trim();

      if (trimmed === "") return null;

      const parsed = Number(trimmed);
      return Number.isNaN(parsed) ? trimmed : parsed;
    }

    return value;
  }

  function toArDigits(n) {
    return String(n).replace(/\d/g, d => "٠١٢٣٤٥٦٧٨٩"[d]);
  }

  /* ========== الأصوات ========== */

  let ttsReady = false;
  let availableVoices = [];

  function loadVoices() {
    availableVoices = window.speechSynthesis.getVoices() || [];

    console.log(
      "Available voices:",
      availableVoices.map(v => ({
        name: v.name,
        lang: v.lang,
        localService: v.localService
      }))
    );
  }

  loadVoices();

  window.speechSynthesis.onvoiceschanged = () => {
    loadVoices();
  };

  enableBtn.onclick = () => {
    try {
      window.speechSynthesis.cancel();
      window.speechSynthesis.resume();
    } catch (e) {}

    ttsReady = true;
    soundGate.style.display = "none";
    statusEl.textContent = "الصوت مفعل — في انتظار النداء";

    try {
      const unlock = new SpeechSynthesisUtterance("Ready");
      unlock.volume = 0.01;
      unlock.lang = "en-US";
      window.speechSynthesis.speak(unlock);
    } catch (e) {}
  };

  function pickArabicVoice() {
    const voices = availableVoices.length
      ? availableVoices
      : window.speechSynthesis.getVoices() || [];

    const byName = voices.find(v =>
      /naayf|naif|hoda|maged|majed|arabic/i.test(v.name)
    );

    if (byName) return byName;

    const byLang = voices.find(v =>
      /^ar([-_]|$)/i.test(v.lang)
    );

    return byLang || null;
  }

  function pickEnglishVoice() {
    const voices = availableVoices.length
      ? availableVoices
      : window.speechSynthesis.getVoices() || [];

    const preferred = voices.find(v =>
      /samantha|daniel|zira|david|google.*english/i.test(v.name)
    );

    if (preferred) return preferred;

    return voices.find(v =>
      /^en([-_]|$)/i.test(v.lang)
    ) || null;
  }

  function speakArabicOnce(text) {
    return new Promise(resolve => {
      if (!ttsReady || !("speechSynthesis" in window)) {
        resolve();
        return;
      }

      const arabicVoice = pickArabicVoice();

      if (!arabicVoice) {
        console.error("No Arabic voice is installed or exposed by this browser.");
        statusEl.textContent = "لا يوجد صوت عربي متاح في هذا المتصفح أو الجهاز";
        resolve();
        return;
      }

      text = text
        .replace(/[ٌٍْـ]/g, "")
        .replace(/\s+/g, " ")
        .trim();

      const utterance = new SpeechSynthesisUtterance(text);

      utterance.lang = arabicVoice.lang || "ar-SA";
      utterance.voice = arabicVoice;
      utterance.rate = 1.1;
      utterance.pitch = 1;
      utterance.volume = 1;

      let completed = false;

      function finish() {
        if (completed) return;
        completed = true;
        resolve();
      }

      utterance.onend = finish;

      utterance.onerror = event => {
        console.error("Arabic speech error:", event.error);
        finish();
      };

      window.speechSynthesis.speak(utterance);
      setTimeout(finish, 15000);
    });
  }

  function speakEnglishOnce(text) {
    return new Promise(resolve => {
      if (!ttsReady || !("speechSynthesis" in window)) {
        resolve();
        return;
      }

      const englishVoice = pickEnglishVoice();
      const utterance = new SpeechSynthesisUtterance(text);

      utterance.lang = englishVoice?.lang || "en-US";

      if (englishVoice) {
        utterance.voice = englishVoice;
      }

      utterance.rate = 1;
      utterance.pitch = 1;
      utterance.volume = 1;

      let completed = false;

      function finish() {
        if (completed) return;
        completed = true;
        resolve();
      }

      utterance.onend = finish;

      utterance.onerror = event => {
        console.error("English speech error:", event.error);
        finish();
      };

      window.speechSynthesis.speak(utterance);
      setTimeout(finish, 15000);
    });
  }

  /* ========== الأرقام العربية ========== */

  function fixNumberWord(n) {
    const map = {
      1: "واحِد",
      2: "اِثنان",
      3: "ثَلاثَة",
      4: "أَربَعَة",
      5: "خَمسَة",
      6: "سِتَّة",
      7: "سَبعَة",
      8: "ثَمانِيَة",
      9: "تِسعَة",
      10: "عَشَرَة"
    };

    return map[n] ? map[n] : toArDigits(n);
  }

  /* ========== الجملة العربية الأصلية ========== */

  function buildArabicPhrase(n, w) {
    const z = "\u200C";
    const num = toArDigits(n);

    const wnum =
      w == null || w === ""
        ? ""
        : fixNumberWord(w);

    if (!wnum) {
      return `تَذْكِرَةُ رقم${z} ${num}`;
    }

    return (
      `تَذْكِرَةُ${z} رقم${z} ${num} ` +
      `الرجاء${z} التوجه${z} إلى${z} ` +
      `الشُبّاك${z} رقم${z} ${wnum}`
    );
  }

  /* ========== الجملة الإنجليزية ========== */

  function buildEnglishPhrase(n, w) {
    if (w == null || w === "") {
      return `Ticket number ${n}`;
    }

    return (
      `Ticket number ${n}. ` +
      `Please proceed to counter number ${w}`
    );
  }

  /* ========== الطابور الصوتي ========== */

  const queue = [];
  const processed = new Set();

  let playing = false;
  const bootTimestamp = Date.now() - 5000;

  function enqueue(item) {
    queue.push(item);

    if (!playing) {
      playNext();
    }
  }

  async function playNext() {
    if (queue.length === 0) {
      playing = false;

      statusEl.textContent =
        ttsReady
          ? "الصوت مفعل — في انتظار النداء"
          : "الصوت غير مفعل";

      return;
    }

    playing = true;

    const item = queue.shift();
    const number = item.number;
    const windowNumber = item.windowNum;

    tNumEl.textContent = toArDigits(number);
    tNumEnEl.textContent = number;

    if (windowNumber != null && windowNumber !== "") {
      wNumEl.textContent = toArDigits(windowNumber);
      wNumEnEl.textContent = windowNumber;

      wWrap.style.display = "inline";
      wWrapEn.style.display = "inline";
    } else {
      wWrap.style.display = "none";
      wWrapEn.style.display = "none";
    }

    callEl.style.display = "block";
    statusEl.textContent = `جاري نداء التذكرة ${number}`;

    try {
      await db.ref(`${ROOT}/activeCall`).set({
        number:number,
        window:windowNumber ?? null,
        ts:firebase.database.ServerValue.TIMESTAMP
      });
    } catch (e) {
      console.error("activeCall error:", e);
    }

    const arabicPhrase = buildArabicPhrase(number, windowNumber);
    const englishPhrase = buildEnglishPhrase(number, windowNumber);

    await speakArabicOnce(arabicPhrase);
    await wait(500);
    await speakEnglishOnce(englishPhrase);
    await wait(1000);

    playNext();
  }

  /* ========== جلب رقم الشباك ========== */

  async function resolveWindow(callValue, ticketNumber) {
    let candidate =
      callValue.window ??
      callValue.win ??
      callValue.windowNum ??
      callValue.counter ??
      null;

    candidate = normalizeValue(candidate);

    if (candidate == null) {
      try {
        const assignmentSnapshot =
          await db
            .ref(`${ROOT}/assignment/${ticketNumber}/window`)
            .get();

        if (assignmentSnapshot.exists()) {
          candidate = normalizeValue(assignmentSnapshot.val());
        }
      } catch (e) {
        console.error("assignment error:", e);
      }
    }

    if (candidate == null) {
      try {
        const operatorWindowSnapshot =
          await db
            .ref(`${ROOT}/operatorWindow`)
            .get();

        if (operatorWindowSnapshot.exists()) {
          candidate = normalizeValue(operatorWindowSnapshot.val());
        }
      } catch (e) {
        console.error("operatorWindow error:", e);
      }
    }

    return candidate;
  }

  /* ========== الاستماع إلى main_TTO/calls ========== */

  db.ref(`${ROOT}/calls`)
    .orderByChild("ts")
    .startAt(bootTimestamp)
    .on("child_added", async snapshot => {
      const key = snapshot.key;
      const value = snapshot.val() || {};

      if (processed.has(key)) return;
      processed.add(key);

      const ticketNumber = Number(value.number);

      if (!ticketNumber || Number.isNaN(ticketNumber)) {
        return;
      }

      const windowNumber =
        await resolveWindow(value, ticketNumber);

      enqueue({
        number:ticketNumber,
        windowNum:windowNumber
      });
    });

})();
</script>

</body>
</html>
